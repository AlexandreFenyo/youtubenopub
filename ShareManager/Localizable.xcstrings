    "No debug logs yet.\nShare a URL to see logs appear here.": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "لا توجد سجلات تصحيح بعد.\nشارك رابطًا لرؤية السجلات هنا."
          }
        },
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "এখনও কোনো ডিবাগ লগ নেই।\nএখানে লগ দেখতে একটি URL শেয়ার করুন।"
          }
        },
        "ca": {
          "stringUnit": {
            "state": "translated",
            "value": "Encara no hi ha registres de depuració.\nComparteix un URL per veure els registres aquí."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Zatím žádné ladicí protokoly.\nSdílejte URL, abyste zde viděli protokoly."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Ingen fejlfindingslogs endnu.\nDel en URL for at se logs her."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Noch keine Debug-Protokolle.\nTeile eine URL, damit Protokolle hier erscheinen."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Δεν υπάρχουν ακόμα αρχεία καταγραφής.\nΜοιραστείτε ένα URL για να εμφανιστούν εδώ."
