    "Limit of %@ AI calls reached for this item — no further AI invocations.": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "تم بلوغ حد %@ من استدعاءات الذكاء الاصطناعي لهذا العنصر — لن تُجرى أي استدعاءات إضافية."
          }
        },
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "এই আইটেমের জন্য %@ AI কলের সীমায় পৌঁছেছে — আর কোনো AI ব্যবহার হবে না।"
          }
        },
        "ca": {
          "stringUnit": {
            "state": "translated",
            "value": "S'ha assolit el límit de %@ invocacions d'IA per a aquest element — no s'invocarà més la IA."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Limit %@ volání AI pro tuto položku byl dosažen — další volání AI již neproběhnou."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Grænsen på %@ AI-kald er nået for dette element — flere AI-kald udføres ikke."
          }
        },
        "de": {
