    "Deleting this folder also deletes every item it contains.": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "سيؤدي حذف هذا المجلد أيضًا إلى حذف جميع العناصر التي يحتوي عليها."
          }
        },
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "এই ফোল্ডারটি মুছে ফেললে এর মধ্যে থাকা সমস্ত আইটেমও মুছে যাবে।"
          }
        },
        "ca": {
          "stringUnit": {
            "state": "translated",
            "value": "Suprimir aquesta carpeta també eliminarà tots els elements que conté."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Smazáním této složky se odstraní i všechny její položky."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Sletning af denne mappe sletter også alle dens emner."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Wenn du diesen Ordner löschst, werden auch alle darin enthaltenen Objekte gelöscht."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Η διαγραφή αυτού του φακέλου θα διαγράψει και όλα τα στοιχεία που περιέχει."
          }
        },
        "en-AU": {
          "stringUnit": {
            "state": "translated",
            "value": "Deleting this folder also deletes every item it contains."
          }
        },
        "en-CA": {
          "stringUnit": {
            "state": "translated",
            "value": "Deleting this folder also deletes every item it contains."
          }
        },
        "en-GB": {
          "stringUnit": {
            "state": "translated",
            "value": "Deleting this folder also deletes every item it contains."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Eliminar esta carpeta también eliminará todos los elementos que contiene."
          }
        },
        "es-MX": {
          "stringUnit": {
            "state": "translated",
            "value": "Eliminar esta carpeta también eliminará todos los elementos que contiene."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Tämän kansion poistaminen poistaa myös kaikki sen sisältämät kohteet."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Supprimer ce dossier supprime également tous les éléments qu'il contient."
          }
        },
        "fr-CA": {
          "stringUnit": {
            "state": "translated",
            "value": "Supprimer ce dossier supprime également tous les éléments qu'il contient."
          }
        },
        "gu": {
          "stringUnit": {
            "state": "translated",
            "value": "આ ફોલ્ડર કાઢી નાખવાથી તેની અંદરની બધી આઇટમ્સ પણ કાઢી નાખવામાં આવશે."
          }
        },
        "he": {
          "stringUnit": {
            "state": "translated",
            "value": "מחיקת תיקייה זו תמחק גם את כל הפריטים שהיא מכילה."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "यह फ़ोल्डर हटाने से इसमें मौजूद सभी आइटम भी हट जाएँगे।"
          }
        },
        "hr": {
          "stringUnit": {
            "state": "translated",
            "value": "Brisanjem ove mape brišu se i sve stavke u njoj."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "A mappa törlésével az abban lévő összes elem is törlődik."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Menghapus folder ini juga akan menghapus semua item di dalamnya."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Eliminando questa cartella verranno eliminati anche tutti gli elementi in essa contenuti."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "このフォルダを削除すると、その中のすべての項目も削除されます。"
          }
        },
        "kn": {
          "stringUnit": {
            "state": "translated",
            "value": "ಈ ಫೋಲ್ಡರ್ ಅಳಿಸಿದರೆ ಅದರಲ್ಲಿರುವ ಎಲ್ಲ ಐಟಂಗಳೂ ಅಳಿಸಲ್ಪಡುತ್ತವೆ."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "이 폴더를 삭제하면 폴더 안에 있는 모든 항목도 함께 삭제됩니다."
          }
        },
        "ml": {
          "stringUnit": {
            "state": "translated",
            "value": "ഈ ഫോൾഡർ ഇല്ലാതാക്കിയാൽ അതിലെ എല്ലാ ഇനങ്ങളും ഇല്ലാതാകും."
          }
        },
        "mr": {
          "stringUnit": {
            "state": "translated",
            "value": "हा फोल्डर हटवल्याने त्यातील सर्व आयटमदेखील हटवले जातील."
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Memadamkan folder ini juga akan memadamkan semua item di dalamnya."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Når du sletter denne mappen, slettes også alle elementer i den."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Door deze map te verwijderen, worden ook alle items erin verwijderd."
          }
        },
        "or": {
          "stringUnit": {
            "state": "translated",
            "value": "ଏହି ଫୋଲ୍ଡର୍ ଡିଲିଟ୍ କଲେ ଏଥିରେ ଥିବା ସବୁ ଆଇଟମ୍ ମଧ୍ୟ ଡିଲିଟ୍ ହେବ।"
          }
        },
        "pa": {
          "stringUnit": {
            "state": "translated",
            "value": "ਇਸ ਫੋਲਡਰ ਨੂੰ ਹਟਾਉਣ ਨਾਲ ਇਸ ਵਿੱਚ ਮੌਜੂਦ ਸਾਰੀਆਂ ਆਈਟਮਾਂ ਵੀ ਹਟ ਜਾਣਗੀਆਂ।"
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Usunięcie tego folderu spowoduje także usunięcie wszystkich zawartych w nim elementów."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Apagar esta pasta também apaga todos os itens que contém."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Ștergerea acestui dosar va șterge și toate elementele din el."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Удаление этой папки также удалит все содержащиеся в ней элементы."
          }
        },
        "sk": {
          "stringUnit": {
            "state": "translated",
            "value": "Odstránením tohto priečinka sa odstránia aj všetky jeho položky."
          }
        },
        "sl": {
          "stringUnit": {
            "state": "translated",
            "value": "Z brisanjem te mape se izbrišejo tudi vsi elementi v njej."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Om du raderar den här mappen raderas även alla objekt i den."
          }
        },
        "ta": {
          "stringUnit": {
            "state": "translated",
            "value": "இந்தக் கோப்புறையை நீக்கினால் அதில் உள்ள அனைத்து உருப்படிகளும் நீக்கப்படும்."
          }
        },
        "te": {
          "stringUnit": {
            "state": "translated",
            "value": "ఈ ఫోల్డర్‌ను తొలగించడం వల్ల దానిలోని అన్ని అంశాలు కూడా తొలగించబడతాయి."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "การลบโฟลเดอร์นี้จะลบรายการทั้งหมดในโฟลเดอร์ด้วย"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Bu klasörü silmek, içindeki tüm öğeleri de siler."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Видалення цієї папки також видалить усі її елементи."
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "اس فولڈر کو حذف کرنے سے اس میں موجود تمام اشیاء بھی حذف ہو جائیں گی۔"
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Xóa thư mục này cũng sẽ xóa mọi mục bên trong."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "删除此文件夹会同时删除其中包含的所有项目。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "刪除此資料夾也會一併刪除其中的所有項目。"
