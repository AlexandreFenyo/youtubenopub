        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Bạn đã thực hiện hơn %lld yêu cầu AI trong %lld phút qua. Mỗi lệnh gọi tốn tín dụng API — vui lòng đảm bảo đây là chủ ý. Bộ đếm đã được đặt lại."
          }
        },
        "zh-Hans": {
          "stringUnit": {
