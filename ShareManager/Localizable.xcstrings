        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ersetzen löscht vorher alles. Zusammenführen behält deine aktuellen Objekte, Ordner und Einstellungen und fügt die importierten hinzu."
          }
        },
        "el" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Η αντικατάσταση διαγράφει τα πάντα πριν την επαναφορά. Η συγχώνευση διατηρεί τα τρέχοντα στοιχεία, φακέλους και ρυθμίσεις και προσθέτει τα εισαγόμενα."
          }
        },
        "en-AU" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Replace deletes everything before restoring. Merge keeps your current items, folders and settings, and adds the imported ones."
          }
