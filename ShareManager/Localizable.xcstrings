        "es-MX" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Reemplazar elimina todo antes de restaurar. Combinar mantiene tus elementos, carpetas y ajustes actuales y añade los importados."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Korvaa poistaa kaiken ennen palautusta. Yhdistä säilyttää nykyiset kohteet, kansiot ja asetukset ja lisää tuodut."
