        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "আপনি গত ৫ মিনিটে ২০-এর বেশি AI অনুরোধ করেছেন। প্রতিটি কল API ক্রেডিট খরচ করে — অনুগ্রহ করে নিশ্চিত করুন যে এটি ইচ্ছাকৃত। কাউন্টার রিসেট করা হয়েছে।"
          }
        },
        "ca": {
