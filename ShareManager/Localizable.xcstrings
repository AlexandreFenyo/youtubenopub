        "bn" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "এই অপারেশন সমস্ত সিঙ্ক না করা ফোল্ডার ও তাদের কনটেন্ট, সেইসাথে Default ফোল্ডারের কনটেন্ট মুছে ফেলে। iCloud-এর সাথে সিঙ্ক করা ফোল্ডারগুলি সংরক্ষিত হয়।"
          }
        },
        "ca" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Aquesta operació elimina totes les carpetes no sincronitzades i el seu contingut, així com el contingut de la carpeta Default. Les carpetes sincronitzades amb iCloud es conserven."
