          }
        },
        "es-MX": {
          "stringUnit": {
            "state": "translated",
            "value": "Aún no hay registros de depuración.\nComparte una URL para ver los registros aquí."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Ei vielä virheenkorjauslokeja.\nJaa URL, niin lokit näkyvät täällä."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Pas encore de journaux de débogage.\nPartagez une URL pour voir les journaux apparaître ici."
          }
        },
        "fr-CA": {
          "stringUnit": {
            "state": "translated",
            "value": "Pas encore de journaux de débogage.\nPartagez une URL pour voir les journaux apparaître ici."
          }
        },
        "gu": {
          "stringUnit": {
            "state": "translated",
            "value": "હજુ સુધી કોઈ ડિબગ લૉગ્સ નથી.\nઅહીં લૉગ્સ જોવા માટે એક URL શેર કરો."
          }
        },
        "he": {
          "stringUnit": {
            "state": "translated",
            "value": "אין עדיין יומני איתור באגים.\nשתף כתובת URL כדי שיופיעו כאן יומנים."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "अभी तक कोई डीबग लॉग नहीं।\nलॉग यहाँ देखने के लिए एक URL साझा करें।"
          }
        },
        "hr": {
          "stringUnit": {
            "state": "translated",
            "value": "Još nema zapisnika za otklanjanje pogrešaka.\nPodijelite URL da vidite zapisnike ovdje."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "Még nincsenek hibakeresési naplók.\nOssz meg egy URL-t, hogy itt megjelenjenek a naplók."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Belum ada log debug.\nBagikan URL untuk melihat log muncul di sini."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Nessun log di debug ancora.\nCondividi un URL per vedere i log qui."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "まだデバッグログはありません。\nURLを共有するとログがここに表示されます。"
          }
        },
        "kn": {
          "stringUnit": {
            "state": "translated",
            "value": "ಇನ್ನೂ ಯಾವುದೇ ಡೀಬಗ್ ಲಾಗ್‌ಗಳಿಲ್ಲ.\nಇಲ್ಲಿ ಲಾಗ್‌ಗಳನ್ನು ನೋಡಲು URL ಹಂಚಿಕೊಳ್ಳಿ."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "아직 디버그 로그가 없습니다.\nURL을 공유하면 여기에 로그가 표시됩니다."
          }
        },
        "ml": {
          "stringUnit": {
            "state": "translated",
            "value": "ഇതുവരെ ഡീബഗ് ലോഗുകളില്ല.\nഇവിടെ ലോഗുകൾ കാണാൻ ഒരു URL പങ്കിടുക."
          }
        },
        "mr": {
          "stringUnit": {
            "state": "translated",
            "value": "अद्याप कोणतेही डीबग लॉग नाहीत.\nलॉग येथे पाहण्यासाठी URL शेअर करा."
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Belum ada log nyahpepijat.\nKongsi URL untuk melihat log di sini."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Ingen feilsøkingslogger ennå.\nDel en URL for å se logger her."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Nog geen foutopsporingslogboeken.\nDeel een URL om hier logboeken te zien verschijnen."
          }
        },
        "or": {
          "stringUnit": {
            "state": "translated",
            "value": "ଏପର୍ଯ୍ୟନ୍ତ କୌଣସି ଡିବଗ୍ ଲଗ୍ ନାହିଁ।\nଏଠାରେ ଲଗ୍ ଦେଖିବା ପାଇଁ ଏକ URL ସେୟାର କରନ୍ତୁ।"
          }
        },
        "pa": {
          "stringUnit": {
            "state": "translated",
            "value": "ਹਾਲੇ ਕੋਈ ਡੀਬੱਗ ਲੌਗ ਨਹੀਂ।\nਇੱਥੇ ਲੌਗ ਵੇਖਣ ਲਈ URL ਸਾਂਝਾ ਕਰੋ।"
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Brak dzienników debugowania.\nUdostępnij adres URL, aby zobaczyć dzienniki tutaj."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Ainda não há registos de depuração.\nPartilhe um URL para ver os registos aqui."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Încă nu există jurnale de depanare.\nDistribuie un URL pentru a vedea jurnalele aici."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Пока нет журналов отладки.\nПоделитесь URL, чтобы журналы появились здесь."
          }
        },
        "sk": {
          "stringUnit": {
            "state": "translated",
            "value": "Zatiaľ žiadne ladiace záznamy.\nZdieľajte URL, aby sa záznamy zobrazili tu."
          }
        },
        "sl": {
          "stringUnit": {
            "state": "translated",
            "value": "Še ni razhroščevalnih dnevnikov.\nDelite URL, da se dnevniki prikažejo tukaj."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Inga felsökningsloggar än.\nDela en URL för att se loggar här."
          }
        },
        "ta": {
          "stringUnit": {
            "state": "translated",
            "value": "இன்னும் பிழைத்திருத்த பதிவுகள் இல்லை.\nஇங்கே பதிவுகளைக் காண ஒரு URL ஐப் பகிரவும்."
          }
        },
        "te": {
          "stringUnit": {
            "state": "translated",
            "value": "ఇంకా డీబగ్ లాగ్‌లు లేవు.\nఇక్కడ లాగ్‌లు చూడటానికి URLని షేర్ చేయండి."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "ยังไม่มีบันทึกการดีบัก\nแชร์ URL เพื่อดูบันทึกปรากฏที่นี่"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Henüz hata ayıklama günlüğü yok.\nBurada günlükleri görmek için bir URL paylaşın."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Поки немає журналів налагодження.\nПоділіться URL, щоб журнали з'явилися тут."
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "ابھی تک کوئی ڈیبگ لاگ نہیں ہے۔\nیہاں لاگ دیکھنے کے لیے ایک URL شیئر کریں۔"
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Chưa có nhật ký gỡ lỗi.\nChia sẻ URL để xem nhật ký xuất hiện tại đây."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "暂无调试日志。\n分享 URL 以在此处查看日志。"
