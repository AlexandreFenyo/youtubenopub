    "Replace deletes everything before restoring. Merge keeps your current items, folders and settings, and adds the imported ones." : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "يحذف الاستبدال كل شيء قبل الاستعادة. يحتفظ الدمج بعناصرك ومجلداتك وإعداداتك الحالية ويضيف ما تم استيراده."
          }
        },
        "bn" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "প্রতিস্থাপন পুনরুদ্ধারের আগে সবকিছু মুছে দেয়। মার্জ আপনার বর্তমান আইটেম, ফোল্ডার এবং সেটিংস রাখে এবং আমদানি করা যোগ করে।"
          }
        },
        "ca" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Substituir esborra tot abans de restaurar. Combinar manté els elements, carpetes i preferències actuals i afegeix els importats."
          }
        },
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nahradit smaže vše před obnovením. Sloučit zachová aktuální položky, složky a nastavení a přidá importované."
          }
        },
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Erstat sletter alt før gendannelse. Flet beholder dine nuværende emner, mapper og indstillinger og tilføjer de importerede."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ersetzen löscht vorher alles. Zusammenführen behält deine aktuellen Objekte, Ordner und Einstellungen und fügt die importierten hinzu."
          }
        },
        "el" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Η αντικατάσταση διαγράφει τα πάντα πριν την επαναφορά. Η συγχώνευση διατηρεί τα τρέχοντα στοιχεία, φακέλους και ρυθμίσεις και προσθέτει τα εισαγόμενα."
          }
        },
        "en-AU" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Replace deletes everything before restoring. Merge keeps your current items, folders and settings, and adds the imported ones."
          }
        },
        "en-CA" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Replace deletes everything before restoring. Merge keeps your current items, folders and settings, and adds the imported ones."
          }
        },
        "en-GB" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Replace deletes everything before restoring. Merge keeps your current items, folders and settings, and adds the imported ones."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Reemplazar elimina todo antes de restaurar. Combinar mantiene tus elementos, carpetas y ajustes actuales y añade los importados."
          }
        },
        "es-MX" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Reemplazar elimina todo antes de restaurar. Combinar mantiene tus elementos, carpetas y ajustes actuales y añade los importados."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Korvaa poistaa kaiken ennen palautusta. Yhdistä säilyttää nykyiset kohteet, kansiot ja asetukset ja lisää tuodut."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Remplacer efface tout avant de restaurer. Fusionner conserve vos éléments, dossiers et réglages actuels et y ajoute ceux importés."
          }
        },
        "fr-CA" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Remplacer efface tout avant de restaurer. Fusionner conserve vos éléments, dossiers et réglages actuels et y ajoute ceux importés."
          }
        },
        "gu" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "બદલવાથી પુનઃસ્થાપન પહેલાં બધું જ કાઢી નાખવામાં આવે છે. મર્જ તમારી હાલની વસ્તુઓ, ફોલ્ડર્સ અને સેટિંગ્સ રાખે છે અને આયાત કરેલા ઉમેરે છે."
          }
        },
        "he" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "החלפה מוחקת הכל לפני השחזור. מיזוג שומר את הפריטים, התיקיות וההגדרות הנוכחיים שלך ומוסיף את אלה שיובאו."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "प्रतिस्थापित करने से पुनर्स्थापन से पहले सब कुछ हट जाता है। मर्ज आपकी वर्तमान आइटम, फ़ोल्डर और सेटिंग्स रखता है और आयात किए गए जोड़ता है।"
          }
        },
        "hr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Zamjena briše sve prije vraćanja. Spajanje zadržava trenutne stavke, mape i postavke te dodaje uvezene."
          }
        },
        "hu" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "A csere mindent töröl a visszaállítás előtt. Az egyesítés megtartja a jelenlegi elemeket, mappákat és beállításokat, és hozzáadja az importáltakat."
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ganti menghapus semuanya sebelum memulihkan. Gabungkan menyimpan item, folder, dan pengaturan saat ini, dan menambahkan yang diimpor."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sostituisci elimina tutto prima di ripristinare. Unisci mantiene gli elementi, le cartelle e le impostazioni attuali e aggiunge quelli importati."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "置換は復元前にすべてを削除します。マージは現在の項目、フォルダ、設定を保持し、インポートしたものを追加します。"
          }
        },
        "kn" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ಬದಲಿಸಿ ಪುನಃಸ್ಥಾಪಿಸುವ ಮೊದಲು ಎಲ್ಲವನ್ನೂ ಅಳಿಸುತ್ತದೆ. ವಿಲೀನವು ನಿಮ್ಮ ಪ್ರಸ್ತುತ ಐಟಂಗಳು, ಫೋಲ್ಡರ್‌ಗಳು ಮತ್ತು ಸೆಟ್ಟಿಂಗ್‌ಗಳನ್ನು ಉಳಿಸಿ, ಆಮದು ಮಾಡಿದವುಗಳನ್ನು ಸೇರಿಸುತ್ತದೆ."
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "교체는 복원 전에 모든 것을 삭제합니다. 병합은 현재 항목, 폴더, 설정을 유지하고 가져온 것을 추가합니다."
          }
        },
        "ml" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "മാറ്റിസ്ഥാപിക്കൽ പുനഃസ്ഥാപിക്കുന്നതിന് മുമ്പ് എല്ലാം ഇല്ലാതാക്കും. ലയിപ്പിക്കൽ നിങ്ങളുടെ നിലവിലെ ഇനങ്ങൾ, ഫോൾഡറുകൾ, ക്രമീകരണങ്ങൾ നിലനിർത്തി ഇറക്കുമതി ചെയ്തവ ചേർക്കും."
          }
        },
        "mr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "बदलल्याने पुनर्स्थापनेपूर्वी सर्वकाही हटवले जाते. विलीनीकरण तुमच्या सध्याच्या आयटम, फोल्डर आणि सेटिंग्ज ठेवते आणि आयात केलेल्या जोडते."
          }
        },
        "ms" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ganti memadamkan semuanya sebelum dipulihkan. Cantum mengekalkan item, folder dan tetapan semasa anda dan menambah yang diimport."
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Erstatt sletter alt før gjenoppretting. Flett beholder dine nåværende elementer, mapper og innstillinger og legger til de importerte."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vervangen verwijdert alles voor het herstellen. Samenvoegen behoudt je huidige items, mappen en instellingen en voegt de geïmporteerde toe."
          }
        },
        "or" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ବଦଳାଇବା ପୁନରୁଦ୍ଧାର ପୂର୍ବରୁ ସବୁକିଛି ଡିଲିଟ୍ କରେ। ମିଶ୍ରଣ ଆପଣଙ୍କ ବର୍ତ୍ତମାନର ଆଇଟମ୍, ଫୋଲ୍ଡର୍ ଏବଂ ସେଟିଂସ୍ ରଖେ ଏବଂ ଆମଦାନୀ ହୋଇଥିବାକୁ ଯୋଡେ।"
          }
        },
        "pa" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ਬਦਲਣਾ ਬਹਾਲੀ ਤੋਂ ਪਹਿਲਾਂ ਸਭ ਕੁਝ ਮਿਟਾ ਦਿੰਦਾ ਹੈ। ਮਿਲਾਉਣਾ ਤੁਹਾਡੀਆਂ ਮੌਜੂਦਾ ਆਈਟਮਾਂ, ਫੋਲਡਰਾਂ ਅਤੇ ਸੈਟਿੰਗਾਂ ਨੂੰ ਰੱਖਦਾ ਹੈ ਅਤੇ ਇੰਪੋਰਟ ਕੀਤੀਆਂ ਨੂੰ ਜੋੜਦਾ ਹੈ।"
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Zastąp usuwa wszystko przed przywróceniem. Scal zachowuje bieżące elementy, foldery i ustawienia oraz dodaje zaimportowane."
          }
        },
        "pt" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Substituir apaga tudo antes de restaurar. Mesclar mantém os itens, pastas e definições atuais e adiciona os importados."
          }
        },
        "ro" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Înlocuiește șterge totul înainte de restaurare. Îmbină păstrează elementele, dosarele și setările curente și le adaugă pe cele importate."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Замена удаляет всё перед восстановлением. Объединение сохраняет текущие элементы, папки и настройки и добавляет импортированные."
          }
        },
        "sk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nahradiť odstráni všetko pred obnovením. Zlúčiť zachová aktuálne položky, priečinky a nastavenia a pridá importované."
          }
        },
        "sl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Zamenjaj izbriše vse pred obnovitvijo. Združi obdrži trenutne elemente, mape in nastavitve ter doda uvožene."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ersätt raderar allt före återställning. Sammanfoga behåller dina nuvarande objekt, mappar och inställningar och lägger till de importerade."
          }
        },
        "ta" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "மாற்று மீட்டெடுக்கும் முன் அனைத்தையும் நீக்குகிறது. ஒன்றிணை உங்கள் தற்போதைய உருப்படிகள், கோப்புறைகள் மற்றும் அமைப்புகளை வைத்து இறக்குமதி செய்தவற்றை சேர்க்கிறது."
          }
        },
        "te" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "భర్తీ పునరుద్ధరణకు ముందు అన్నిటినీ తొలగిస్తుంది. విలీనం మీ ప్రస్తుత అంశాలు, ఫోల్డర్‌లు మరియు సెట్టింగ్‌లను ఉంచి దిగుమతి చేసిన వాటిని జోడిస్తుంది."
          }
        },
        "th" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "แทนที่จะลบทุกอย่างก่อนกู้คืน ผสานจะเก็บรายการ โฟลเดอร์ และการตั้งค่าปัจจุบันของคุณ และเพิ่มที่นำเข้า"
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Değiştir, geri yüklemeden önce her şeyi siler. Birleştir, mevcut öğelerinizi, klasörlerinizi ve ayarlarınızı korur ve içe aktarılanları ekler."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Заміна видаляє все перед відновленням. Об'єднання зберігає поточні елементи, папки та налаштування і додає імпортовані."
          }
        },
        "ur" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "تبدیل بحالی سے پہلے سب کچھ حذف کر دیتا ہے۔ ضم کرنے سے آپ کی موجودہ اشیاء، فولڈرز اور ترتیبات محفوظ رہتی ہیں اور درآمد شدہ شامل ہو جاتی ہیں۔"
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Thay thế xóa mọi thứ trước khi khôi phục. Hợp nhất giữ lại các mục, thư mục và cài đặt hiện tại và thêm các mục đã nhập."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "替换会在恢复前删除所有内容。合并会保留您当前的项目、文件夹和设置，并添加导入的内容。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "取代會在還原前刪除所有內容。合併會保留您目前的項目、資料夾和設定，並加入匯入的內容。"
          }
        }
      }
    },
