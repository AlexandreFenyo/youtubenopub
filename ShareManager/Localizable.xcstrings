            "value": "This app stores URLs and items you share from other apps using the Share button"
          }
        },
        "en-CA": {
          "stringUnit": {
            "state": "translated",
            "value": "This app stores URLs and items you share from other apps using the Share button"
          }
        },
        "en-GB": {
          "stringUnit": {
            "state": "translated",
            "value": "This app stores URLs and items you share from other apps using the Share button"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Esta app almacena las URLs y elementos que compartes desde otras apps usando el botón Compartir"
          }
        },
        "es-MX": {
          "stringUnit": {
            "state": "translated",
            "value": "Esta app almacena las URLs y elementos que compartes desde otras apps usando el botón Compartir"
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Tämä sovellus tallentaa URL-osoitteet ja kohteet, joita jaat muista sovelluksista Jaa-painikkeella"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Cette app stocke les URLs et objets que vous partagez depuis d'autres apps via le bouton Partager"
          }
        },
        "fr-CA": {
          "stringUnit": {
            "state": "translated",
            "value": "Cette app stocke les URLs et objets que vous partagez depuis d'autres apps via le bouton Partager"
          }
        },
        "gu": {
          "stringUnit": {
            "state": "translated",
            "value": "આ ઍપ શેર બટનનો ઉપયોગ કરીને અન્ય ઍપ્સમાંથી તમે શેર કરેલા URLs અને આઇટમ્સ સાચવે છે"
          }
        },
        "he": {
          "stringUnit": {
            "state": "translated",
            "value": "אפליקציה זו שומרת כתובות URL ופריטים שאתה משתף מאפליקציות אחרות באמצעות כפתור השיתוף"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "यह ऐप शेयर बटन का उपयोग करके अन्य ऐप्स से साझा किए गए URLs और आइटम्स को सहेजता है"
          }
        },
        "hr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ova aplikacija sprema URL-ove i stavke koje dijelite iz drugih aplikacija gumbom Podijeli"
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "Ez az alkalmazás elmenti a más alkalmazásokból a Megosztás gombbal megosztott URL-eket és elemeket"
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Aplikasi ini menyimpan URL dan item yang Anda bagikan dari aplikasi lain menggunakan tombol Bagikan"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Questa app archivia gli URL e gli oggetti che condividi da altre app tramite il tasto Condividi"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "このアプリは、他のアプリから共有ボタンで共有したURLとアイテムを保存します"
          }
        },
        "kn": {
          "stringUnit": {
            "state": "translated",
            "value": "ಈ ಅಪ್ಲಿಕೇಶನ್ ಹಂಚಿಕೆ ಬಟನ್ ಬಳಸಿ ಇತರ ಅಪ್ಲಿಕೇಶನ್‌ಗಳಿಂದ ನೀವು ಹಂಚಿಕೊಂಡ URL ಗಳು ಮತ್ತು ಐಟಂಗಳನ್ನು ಸಂಗ್ರಹಿಸುತ್ತದೆ"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "이 앱은 공유 버튼을 사용해 다른 앱에서 공유한 URL과 항목을 저장합니다"
          }
        },
        "ml": {
          "stringUnit": {
            "state": "translated",
            "value": "ഷെയർ ബട്ടൺ ഉപയോഗിച്ച് മറ്റ് ആപ്പുകളിൽ നിന്ന് നിങ്ങൾ പങ്കിടുന്ന URL-കളും ഇനങ്ങളും ഈ ആപ്പ് സംഭരിക്കുന്നു"
          }
        },
        "mr": {
          "stringUnit": {
            "state": "translated",
            "value": "हे ॲप शेअर बटण वापरून इतर ॲप्सवरून तुम्ही शेअर केलेले URLs आणि आयटम साठवते"
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Aplikasi ini menyimpan URL dan item yang anda kongsi dari aplikasi lain menggunakan butang Kongsi"
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Denne appen lagrer URL-er og elementer du deler fra andre apper med Del-knappen"
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Deze app bewaart de URL's en items die je vanuit andere apps deelt via de deelknop"
          }
        },
        "or": {
          "stringUnit": {
            "state": "translated",
            "value": "ଏହି ଆପ୍ ସେୟାର ବଟନ୍ ବ୍ୟବହାର କରି ଅନ୍ୟ ଆପ୍‌ରୁ ଆପଣ ସେୟାର କରିଥିବା URLs ଏବଂ ଆଇଟମ୍ ସଂରକ୍ଷଣ କରେ"
          }
        },
        "pa": {
          "stringUnit": {
            "state": "translated",
            "value": "ਇਹ ਐਪ ਸਾਂਝਾ ਕਰੋ ਬਟਨ ਦੀ ਵਰਤੋਂ ਕਰਕੇ ਹੋਰ ਐਪਾਂ ਤੋਂ ਤੁਸੀਂ ਸਾਂਝੇ ਕੀਤੇ URLs ਅਤੇ ਆਈਟਮ ਨੂੰ ਸਟੋਰ ਕਰਦੀ ਹੈ"
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Ta aplikacja zapisuje adresy URL i elementy udostępniane z innych aplikacji za pomocą przycisku Udostępnij"
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Este app armazena os URLs e itens que você partilha de outros apps usando o botão Partilhar"
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Această aplicație stochează URL-urile și elementele pe care le distribui din alte aplicații folosind butonul Distribuie"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Это приложение сохраняет URL и объекты, которыми вы делитесь из других приложений через кнопку «Поделиться»"
          }
        },
        "sk": {
          "stringUnit": {
            "state": "translated",
            "value": "Táto aplikácia ukladá URL a položky, ktoré zdieľate z iných aplikácií pomocou tlačidla Zdieľať"
          }
        },
        "sl": {
          "stringUnit": {
            "state": "translated",
            "value": "Ta aplikacija shranjuje URL-je in elemente, ki jih delite iz drugih aplikacij z gumbom Deli"
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Denna app sparar webbadresser och objekt som du delar från andra appar via delningsknappen"
          }
        },
        "ta": {
          "stringUnit": {
            "state": "translated",
            "value": "இந்த ஆப்ஸ் பகிர் பொத்தானைப் பயன்படுத்தி பிற ஆப்ஸிலிருந்து நீங்கள் பகிரும் URL கள் மற்றும் உருப்படிகளை சேமிக்கிறது"
          }
        },
        "te": {
          "stringUnit": {
            "state": "translated",
            "value": "ఈ యాప్ షేర్ బటన్‌ను ఉపయోగించి ఇతర యాప్‌ల నుండి మీరు షేర్ చేసే URLలు మరియు అంశాలను నిల్వ చేస్తుంది"
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "แอปนี้บันทึก URL และรายการที่คุณแชร์จากแอปอื่นโดยใช้ปุ่มแชร์"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Bu uygulama, Paylaş düğmesi ile diğer uygulamalardan paylaştığınız URL'leri ve öğeleri saklar"
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Цей застосунок зберігає URL та елементи, якими ви ділитеся з інших застосунків через кнопку «Поділитися»"
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "یہ ایپ شیئر بٹن استعمال کرکے دیگر ایپس سے شیئر کی گئی URLs اور اشیاء کو محفوظ کرتی ہے"
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Ứng dụng này lưu các URL và mục mà bạn chia sẻ từ ứng dụng khác bằng nút Chia sẻ"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "此应用存储您通过分享按钮从其他应用分享的URL和项目"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "此應用程式儲存您透過分享按鈕從其他應用程式分享的URL和項目"
          }
        }
      }
    },
