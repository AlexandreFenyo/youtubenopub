    "You've made more than %@ AI requests in the last %@ minutes. Each call costs API credits — please make sure this is intended. The counter has been reset.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "new",
            "value": "You've made more than %1$@ AI requests in the last %2$@ minutes. Each call costs API credits — please make sure this is intended. The counter has been reset."
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "لقد قمت بأكثر من %@ من طلبات الذكاء الاصطناعي خلال %@ دقيقة الماضية. كل استدعاء يستهلك رصيد واجهة برمجية — يرجى التأكد من أن هذا متعمَّد. تم تصفير العدّاد."
          }
        },
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "আপনি গত %@ মিনিটে %@-এর বেশি AI অনুরোধ করেছেন। প্রতিটি কল API ক্রেডিট খরচ করে — অনুগ্রহ করে নিশ্চিত করুন যে এটি ইচ্ছাকৃত। কাউন্টার রিসেট করা হয়েছে।"
          }
        },
        "ca": {
          "stringUnit": {
            "state": "translated",
            "value": "Heu fet més de %@ sol·licituds d'IA en els darrers %@ minuts. Cada invocació consumeix crèdits d'API — assegureu-vos que és intencionat. S'ha reiniciat el comptador."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "V posledních %@ minutách jste odeslali více než %@ požadavků AI. Každé volání spotřebovává API kredity — ujistěte se, že je to záměr. Počitadlo bylo resetováno."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Du har lavet mere end %@ AI-anmodninger i de sidste %@ minutter. Hvert kald koster API-kreditter — sørg for, at det er tilsigtet. Tælleren er nulstillet."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Du hast in den letzten %@ Minuten mehr als %@ KI-Anfragen gestellt. Jeder Aufruf kostet API-Guthaben — bitte stelle sicher, dass das beabsichtigt ist. Der Zähler wurde zurückgesetzt."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Έχετε κάνει περισσότερα από %@ αιτήματα ΤΝ στα τελευταία %@ λεπτά. Κάθε κλήση κοστίζει σε credits API — βεβαιωθείτε ότι είναι σκόπιμο. Ο μετρητής μηδενίστηκε."
          }
        },
        "en-AU": {
          "stringUnit": {
            "state": "translated",
            "value": "You've made more than %@ AI requests in the last %@ minutes. Each call costs API credits — please make sure this is intended. The counter has been reset."
          }
        },
        "en-CA": {
          "stringUnit": {
            "state": "translated",
            "value": "You've made more than %@ AI requests in the last %@ minutes. Each call costs API credits — please make sure this is intended. The counter has been reset."
          }
        },
        "en-GB": {
          "stringUnit": {
            "state": "translated",
            "value": "You've made more than %@ AI requests in the last %@ minutes. Each call costs API credits — please make sure this is intended. The counter has been reset."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Has hecho más de %@ solicitudes de IA en los últimos %@ minutos. Cada llamada cuesta créditos de API — asegúrate de que sea intencionado. El contador se ha restablecido."
          }
        },
        "es-MX": {
          "stringUnit": {
            "state": "translated",
            "value": "Has hecho más de %@ solicitudes de IA en los últimos %@ minutos. Cada llamada cuesta créditos de API — asegúrate de que sea intencionado. El contador se ha restablecido."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Olet tehnyt yli %@ AI-pyyntöä viimeisen %@ minuutin aikana. Jokainen kutsu kuluttaa API-krediittejä — varmista että tämä on tarkoituksellista. Laskuri on nollattu."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Tu as effectué plus de %@ requêtes IA durant les %@ dernières minutes. Chaque appel consomme des crédits API — assure-toi que c'est intentionnel. Le compteur a été réinitialisé."
          }
        },
        "fr-CA": {
          "stringUnit": {
            "state": "translated",
            "value": "Tu as effectué plus de %@ requêtes IA durant les %@ dernières minutes. Chaque appel consomme des crédits API — assure-toi que c'est intentionnel. Le compteur a été réinitialisé."
          }
        },
        "gu": {
          "stringUnit": {
            "state": "translated",
            "value": "તમે છેલ્લી %@ મિનિટોમાં %@ થી વધુ AI વિનંતીઓ કરી છે. દરેક કૉલ API ક્રેડિટ ખર્ચ કરે છે — કૃપા કરી ખાતરી કરો કે આ ઇરાદાપૂર્વકનું છે. કાઉન્ટર રીસેટ થયું છે."
          }
        },
        "he": {
          "stringUnit": {
            "state": "translated",
            "value": "ביצעת יותר מ-%@ בקשות AI ב-%@ הדקות האחרונות. כל קריאה צורכת קרדיטים של API — אנא ודא שזה מכוון. המונה אופס."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "आपने पिछले %@ मिनटों में %@ से अधिक AI अनुरोध किए हैं। प्रत्येक कॉल API क्रेडिट खर्च करता है — कृपया सुनिश्चित करें कि यह जानबूझकर है। काउंटर रीसेट कर दिया गया है।"
          }
        },
        "hr": {
          "stringUnit": {
            "state": "translated",
            "value": "Napravili ste više od %@ AI zahtjeva u posljednjih %@ minuta. Svaki poziv troši API kredite — provjerite je li to namjerno. Brojač je resetiran."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "Több mint %@ AI kérést indított az elmúlt %@ percben. Minden hívás API krediteket használ fel — kérjük, győződjön meg róla, hogy ez szándékos. A számláló visszaállt."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Anda telah melakukan lebih dari %@ permintaan AI dalam %@ menit terakhir. Setiap pemanggilan menghabiskan kredit API — pastikan ini disengaja. Penghitung telah direset."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Hai effettuato più di %@ richieste IA negli ultimi %@ minuti. Ogni chiamata costa crediti API — assicurati che sia voluto. Il contatore è stato azzerato."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "過去 %@ 分間に %@ 件を超えるAIリクエストを行いました。各呼び出しはAPIクレジットを消費します — 意図的であることを確認してください。カウンタはリセットされました。"
          }
        },
        "kn": {
          "stringUnit": {
            "state": "translated",
            "value": "ನೀವು ಕಳೆದ %@ ನಿಮಿಷಗಳಲ್ಲಿ %@ ಕ್ಕಿಂತ ಹೆಚ್ಚು AI ವಿನಂತಿಗಳನ್ನು ಮಾಡಿದ್ದೀರಿ. ಪ್ರತಿ ಕರೆಯು API ಕ್ರೆಡಿಟ್‌ಗಳನ್ನು ಬಳಸುತ್ತದೆ — ಇದು ಉದ್ದೇಶಪೂರ್ವಕವೆಂದು ಖಚಿತಪಡಿಸಿ. ಕೌಂಟರ್ ಮರುಹೊಂದಿಸಲಾಗಿದೆ."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "지난 %@분 동안 AI 요청을 %@개 이상 보냈습니다. 호출마다 API 크레딧이 소모됩니다 — 의도한 것인지 확인하세요. 카운터가 재설정되었습니다."
          }
        },
        "ml": {
          "stringUnit": {
            "state": "translated",
            "value": "കഴിഞ്ഞ %@ മിനിറ്റിൽ %@-ൽ കൂടുതൽ AI അഭ്യർത്ഥനകൾ നടത്തി. ഓരോ കോളും API ക്രെഡിറ്റുകൾ ചെലവഴിക്കും — ഇത് ഉദ്ദേശ്യപൂർവ്വമാണെന്ന് ഉറപ്പാക്കുക. കൗണ്ടർ പുനഃസജ്ജമാക്കി."
          }
        },
        "mr": {
          "stringUnit": {
            "state": "translated",
            "value": "तुम्ही गेल्या %@ मिनिटांत %@ पेक्षा जास्त AI विनंत्या केल्या आहेत. प्रत्येक कॉल API क्रेडिट खर्च करतो — कृपया हे हेतुपुरस्सर आहे याची खात्री करा. काउंटर रीसेट केला आहे."
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Anda telah membuat lebih daripada %@ permintaan AI dalam %@ minit yang lalu. Setiap panggilan menggunakan kredit API — sila pastikan ini sengaja. Pembilang telah ditetapkan semula."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Du har gjort mer enn %@ AI-forespørsler de siste %@ minuttene. Hvert kall koster API-kreditter — pass på at dette er tilsiktet. Telleren er tilbakestilt."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Je hebt meer dan %@ AI-verzoeken gedaan in de laatste %@ minuten. Elke oproep kost API-credits — zorg ervoor dat dit bedoeld is. De teller is gereset."
          }
        },
        "or": {
          "stringUnit": {
            "state": "translated",
            "value": "ଆପଣ ଗତ %@ ମିନିଟ୍‌ରେ %@ରୁ ଅଧିକ AI ଅନୁରୋଧ କରିଛନ୍ତି। ପ୍ରତ୍ୟେକ କଲ୍ API କ୍ରେଡିଟ୍ ଖର୍ଚ୍ଚ କରେ — ଏହା ଉଦ୍ଦେଶ୍ୟମୂଳକ ଅଟେ ବୋଲି ନିଶ୍ଚିତ କରନ୍ତୁ। କାଉଣ୍ଟର୍ ରିସେଟ୍ ହୋଇଛି।"
          }
        },
        "pa": {
          "stringUnit": {
            "state": "translated",
            "value": "ਤੁਸੀਂ ਪਿਛਲੇ %@ ਮਿੰਟਾਂ ਵਿੱਚ %@ ਤੋਂ ਵੱਧ AI ਬੇਨਤੀਆਂ ਕੀਤੀਆਂ ਹਨ। ਹਰ ਕਾਲ API ਕ੍ਰੈਡਿਟ ਖਰਚ ਕਰਦੀ ਹੈ — ਕਿਰਪਾ ਕਰਕੇ ਯਕੀਨੀ ਬਣਾਓ ਇਹ ਜਾਣਬੁੱਝ ਕੇ ਕੀਤਾ ਗਿਆ। ਕਾਊਂਟਰ ਰੀਸੈੱਟ ਹੋ ਗਿਆ ਹੈ।"
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "W ostatnich %@ minutach wysłano więcej niż %@ żądań AI. Każde wywołanie zużywa kredyty API — upewnij się, że to zamierzone. Licznik został zresetowany."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Fez mais de %@ pedidos de IA nos últimos %@ minutos. Cada chamada consome créditos da API — confirme se é intencional. O contador foi reiniciado."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Ai făcut mai mult de %@ cereri AI în ultimele %@ minute. Fiecare apel costă credite API — asigură-te că e intenționat. Contorul a fost resetat."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Вы сделали более %@ запросов к ИИ за последние %@ минут. Каждый вызов расходует API-кредиты — убедитесь, что это намеренно. Счётчик сброшен."
          }
        },
        "sk": {
          "stringUnit": {
            "state": "translated",
            "value": "V posledných %@ minútach ste odoslali viac ako %@ požiadaviek AI. Každé volanie spotrebúva API kredity — uistite sa, že je to zámer. Počítadlo bolo resetované."
          }
        },
        "sl": {
          "stringUnit": {
            "state": "translated",
            "value": "V zadnjih %@ minutah ste poslali več kot %@ zahtev UI. Vsak klic porabi API kredite — preverite, ali je to namerno. Števec je ponastavljen."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Du har gjort fler än %@ AI-förfrågningar under de senaste %@ minuterna. Varje anrop kostar API-krediter — säkerställ att detta är avsiktligt. Räknaren har återställts."
          }
        },
        "ta": {
          "stringUnit": {
            "state": "translated",
