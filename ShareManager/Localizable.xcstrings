    "This app stores URLs and items you share from other apps using the Share button": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "يحفظ هذا التطبيق الروابط والعناصر التي تشاركها من تطبيقات أخرى عبر زر المشاركة"
          }
        },
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "এই অ্যাপটি শেয়ার বোতাম ব্যবহার করে অন্যান্য অ্যাপ থেকে শেয়ার করা URL এবং আইটেম সংরক্ষণ করে"
          }
        },
        "ca": {
          "stringUnit": {
            "state": "translated",
            "value": "Aquesta app desa els URLs i elements que comparteixes des d'altres apps amb el botó Compartir"
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Tato aplikace ukládá URL a položky, které sdílíte z jiných aplikací tlačítkem Sdílet"
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Denne app gemmer URL'er og emner, du deler fra andre apps med Del-knappen"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Diese App speichert URLs und Objekte, die du aus anderen Apps über den Teilen-Knopf teilst"
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Αυτή η εφαρμογή αποθηκεύει URL και στοιχεία που μοιράζεστε από άλλες εφαρμογές μέσω του κουμπιού Κοινής χρήσης"
          }
        },
        "en-AU": {
          "stringUnit": {
